# Garmin Connect credentials
GARMIN_EMAIL=
GARMIN_PASSWORD=

# Supabase project (use service_role key, not anon key)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Optional: token cache directory (default: ~/.garmin_tokens)
# GARMIN_TOKEN_DIR=~/.garmin_tokens

# Optional: delay between Garmin API calls in seconds (default: 1.0)
# FETCH_DELAY=1.0
