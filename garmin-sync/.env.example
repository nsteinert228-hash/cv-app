# Garmin Connect credentials
GARMIN_EMAIL=
GARMIN_PASSWORD=

# Supabase project (use service_role key, not anon key)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Supabase Auth user UUID (used by sync-cron.sh for scheduled syncs)
# Find it in Supabase Dashboard → Authentication → Users
GARMIN_SYNC_USER_ID=

# Optional: token cache directory (default: ~/.garmy)
# GARMIN_TOKEN_DIR=~/.garmy

# Optional: delay between Garmin API calls in seconds (default: 1.0)
# FETCH_DELAY=1.0
